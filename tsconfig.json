{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": false,
    "paths": {
      "@/lib/*": ["./lib/*"],
      "@/*": ["./app/*"]
    },
    "types": ["vite/client"]
  },
  "include": [
    "app",
    "vite.config.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
